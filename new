import { supabase } from '../lib/supabaseClient';
import { askTrendlyAIWithHistory, type TrendlyAIServerReply } from '../lib/localAI';

export interface ConversationMessage {
  role: 'user' | 'assistant';
  content: string;
}

export interface AIStylistStructuredResponse {
  message: string;
  suggestion: string;
  items: string[];
  summary: string;
}

// ─── Public API ───────────────────────────────────────────────────────────────
export async function getAIStylistResponse(
  userInput: string,
  conversationHistory: ConversationMessage[]
): Promise<AIStylistStructuredResponse> {
  try {
    // We can also inject a system personality hint here if the server supports history
    const response = await askTrendlyAIWithHistory(userInput, conversationHistory);
    return sanitizeServerReply(response, userInput);
  } catch (err: any) {
    console.error('Local AI error:', err);
    const fallback = fallbackReply(userInput);
    return fallback;
  }
}

export async function saveConversationMessage(userId: string, message: string, role: 'user' | 'assistant') {
  const { error } = await supabase.from('ai_conversations').insert([{ user_id: userId, message, role }]);
  if (error) {
    throw error;
  }
}

export async function loadConversationHistory(userId: string): Promise<ConversationMessage[]> {
  const { data, error } = await supabase
    .from('ai_conversations')
    .select('message, role')
    .eq('user_id', userId)
    .order('created_at', { ascending: true })
    .limit(30);
  if (error) {
    throw error;
  }
  if (!data) return [];
  return data.map(row => ({ role: row.role as 'user' | 'assistant', content: row.message as string }));
}

function sanitizeServerReply(reply: TrendlyAIServerReply, prompt: string): AIStylistStructuredResponse {
  const message = String(reply?.message || '').trim();
  const suggestion = String(reply?.suggestion || '').trim();
  const summary = String(reply?.summary || '').trim();
  const items = Array.isArray(reply?.items) ? reply.items.map((item) => String(item).trim()).filter(Boolean) : [];

  if (!message && !summary) {
    return fallbackReply(prompt);
  }

  return {
    message: message || summary,
    suggestion,
    items,
    summary: summary || suggestion,
  };
}

