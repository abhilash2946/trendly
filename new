function detectEventType(text: string) {
  if (/(wedding|weddng|marriage|marrage|mariage|reception|engagement|shaadi)/i.test(text)) return 'wedding';
  if (/(office|work|meeting|corporate|conference|interview|formal)/i.test(text)) return 'office';
  if (/(birthday|bday|birth day)/i.test(text)) return 'birthday';
  if (/(party|club|celebration|rave)/i.test(text)) return 'party';
  if (/(date|dinner|night out|nightout)/i.test(text)) return 'date';
  if (/(festival|festive|ethnic|traditional|pooja|puja|diwali|eid|holi)/i.test(text)) return 'festival';
  if (/(college|outing|casual|weekend|friends)/i.test(text)) return 'casual';
  return null;
}